# VibeRoute Backend Environment Variables Template
# Copy this to .env and fill in your actual keys

# Required: Google Gemini API Key (Get from https://makersuite.google.com/app/apikey)
GOOGLE_GEMINI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# Required: Google Maps API Key (Get from Google Cloud Console)
# Used for: Geocoding (location lookup), shareable links
# Must enable: Geocoding API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxx


# Optional: Spotify Recommendations (Get from Spotify Developers)
SPOTIFY_API_KEY=your_spotify_token_here

# Flask
FLASK_ENV=development

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=1
